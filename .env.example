# NASA TAP API endpoint (optional, has default)
NASA_TAP_BASE_URL=https://exoplanetarchive.ipac.caltech.edu/TAP/sync

# Disk cache TTL in hours (default: 24). Data is loaded from file if younger than this.
DISK_CACHE_TTL_HOURS=24

# Path to the disk cache file (default: ./data/exoplanets-cache.json)
# DISK_CACHE_PATH=./data/exoplanets-cache.json

# In-memory refresh interval in seconds (default: 3600). Triggers a re-check against disk cache.
CACHE_TTL_SECONDS=3600